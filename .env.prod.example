# ── AMIS Production Environment Variables ────────────────────────────────────
# Copy this file to .env on the VPS and fill in every value.
# Never commit the real .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=amis
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=amis

# Password for the app_user role (lower-privilege role used by the API at runtime)
APP_DB_PASSWORD=change-me-app-password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-64-byte-random-hex-string

# ── API ───────────────────────────────────────────────────────────────────────
# The origin that the browser frontend is served from (used in CORS header)
CORS_ORIGIN=https://amis.institute

# ── Web (baked into the React bundle at build time) ───────────────────────────
VITE_API_URL=https://api.amis.institute
